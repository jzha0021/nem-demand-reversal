# Streamlit Cloud secrets — copy this file to `.streamlit/secrets.toml`
# (which is gitignored) and fill in real values. Streamlit Cloud reads
# the real file from the deployment's "Secrets" tab in its UI; the on-
# disk file is only used for local `streamlit run` testing.

[snowflake]
account   = "<YOUR_SNOWFLAKE_ACCOUNT>"  # e.g. ABC12345-XY67890
# Dedicated Streamlit user — separate from the admin user. Password is
# the strong random secret you set via
#   ALTER USER STREAMLIT_DASHBOARD SET PASSWORD = '<value>';
# in Snowsight (see db/snowflake/01_account_setup.sql section 5).
# Streamlit Cloud reads from the deployment's Secrets tab, NOT this
# file — this template only documents local-dev shape.
user      = "STREAMLIT_DASHBOARD"
password  = ""
role      = "R_NEM_READ"
warehouse = "WH_NEM"
database  = "NEM"
schema    = "ANALYTICS"
