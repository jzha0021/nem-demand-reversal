# Streamlit Cloud secrets — copy this file to `.streamlit/secrets.toml`
# (which is gitignored) and fill in real values. Streamlit Cloud reads
# the real file from the deployment's "Secrets" tab in its UI; the on-
# disk file is only used for local `streamlit run` testing.

[snowflake]
account   = "<YOUR_SNOWFLAKE_ACCOUNT>"  # e.g. ABC12345-XY67890
# Dedicated Streamlit user — separate from the admin user. RSA key-pair
# auth (paid Snowflake forces MFA on TYPE=PERSON; STREAMLIT_DASHBOARD is
# TYPE=SERVICE with the public-key fingerprint registered via:
#   ALTER USER STREAMLIT_DASHBOARD SET TYPE = SERVICE,
#       RSA_PUBLIC_KEY = '<body of streamlit.pub, no PEM headers>';
# in Snowsight). Streamlit Cloud reads from the deployment's Secrets
# tab, NOT this file — this template only documents the local-dev shape.
user        = "STREAMLIT_DASHBOARD"
# Multi-line raw PEM body, including BEGIN/END lines. Triple-quoted so
# the line breaks are preserved verbatim.
private_key = """-----BEGIN PRIVATE KEY-----
<paste contents of streamlit.p8 here>
-----END PRIVATE KEY-----"""
role        = "R_NEM_READ"
warehouse   = "WH_NEM"
database    = "NEM"
schema      = "ANALYTICS"
