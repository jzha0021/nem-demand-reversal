# Local Postgres connection — copy this file to .env and fill in DB_PWD.
# .env is git-ignored; .env.example is committed.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=nem
DB_USER=postgres
DB_PWD=

# Optional: override default schema (used by load_to_postgres.py)
DB_SCHEMA=raw

# S3 raw-zip mirror (used by fetch_*_current.py and backfill_to_snowflake.py).
# Opt-in: leave S3_BUCKET blank to skip S3 entirely (Postgres-only mode).
# Locally, set AWS_PROFILE=nem to pick up the local-dev-nem credentials in
# ~/.aws/credentials. In GitHub Actions, OIDC populates AWS_* automatically
# so AWS_PROFILE should remain unset.
S3_BUCKET=<YOUR_S3_BUCKET>
AWS_REGION=ap-southeast-2
AWS_PROFILE=nem

# Snowflake target for predict.py / backfill / check_pipe_status / Streamlit.
# Authentication uses RSA key-pair (Snowflake forces MFA on TYPE=PERSON
# users on paid accounts; pipelines must use a TYPE=SERVICE user with a
# public key registered via ALTER USER ... SET RSA_PUBLIC_KEY = '...').
#
# Generate a key pair:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM \
#       -out ~/.snowflake/nem_ci.p8 -nocrypt
#   openssl rsa -in ~/.snowflake/nem_ci.p8 -pubout -out ~/.snowflake/nem_ci.pub
# Register the public-key body (strip the BEGIN/END headers) in Snowsight.
#
# Local: SNOWFLAKE_PRIVATE_KEY_PATH points at the .p8 file.
# CI/Streamlit Cloud: SNOWFLAKE_PRIVATE_KEY holds the raw multi-line PEM
# directly in secrets (path doesn't exist in those environments).
# Leave both blank to skip Snowflake; predict / dbt / backfill fall back
# to Postgres unless --target snowflake is passed.
SNOWFLAKE_ACCOUNT=<YOUR_SNOWFLAKE_ACCOUNT>
SNOWFLAKE_USER=<YOUR_SNOWFLAKE_SERVICE_USER>
SNOWFLAKE_PRIVATE_KEY_PATH=
# SNOWFLAKE_PRIVATE_KEY=         # CI/cloud only — raw PEM contents
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=   # set only if the .p8 was encrypted
SNOWFLAKE_ROLE=R_NEM_RW
SNOWFLAKE_WAREHOUSE=WH_NEM
SNOWFLAKE_DATABASE=NEM
SNOWFLAKE_SCHEMA=ANALYTICS
