# Secrets
.env
.streamlit/secrets.toml

# Data — too large for git, regenerable from nemosis / Open-Meteo
data/raw/
data/parquet/

# ML artefacts — exception for the frozen leak-free LR artefact (3KB, the
# single source of truth for predict.py; CI cannot run inference without it).
# All other joblib files (notebook scratch dumps, retrain experiments) stay
# ignored.
models/*.joblib
!models/leak_free_lr.joblib

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.pytest_cache/

# IDE
.vscode/
.idea/

# OS / editor scratch
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp
~$*

# Private planning docs
docs/PHASE2_PLAN.md

# dbt build artefacts
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# dbt also writes a logs/ at repo root when invoked from outside dbt/
logs/
