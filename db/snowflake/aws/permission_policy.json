{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSnowflakeListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::<YOUR_S3_BUCKET>"
    },
    {
      "Sid": "AllowSnowflakeReadObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion"
      ],
      "Resource": "arn:aws:s3:::<YOUR_S3_BUCKET>/*"
    }
  ]
}
